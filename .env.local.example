# Resonance — environment variables.
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# See README.md → "External services" for signup links and a walkthrough.

# ─── Database ──────────────────────────────────────────────────────────────
# Neon Postgres pooled connection string.
# console.neon.tech → project → "Connection string" → "Pooled connection".
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# ─── Auth (Clerk) ──────────────────────────────────────────────────────────
# dashboard.clerk.com → API Keys.
# Same publishable key is used on both server and client (the client one needs
# the VITE_ prefix below so Vite exposes it to the browser).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ─── AI (Anthropic Claude) ─────────────────────────────────────────────────
# console.anthropic.com → API Keys. Required from step 4 onward.
ANTHROPIC_API_KEY=

# ─── Media providers ───────────────────────────────────────────────────────
# All required from step 6 onward. Without them the corresponding media types
# (movies/TV, games) won't return results, but the rest of the app still works.

# TMDB — movies + TV.
# themoviedb.org → settings → API → "API Read Access Token" (the long JWT,
# not the v3 API key).
TMDB_API_KEY=

# IGDB — games. IGDB is gated behind Twitch credentials; the server exchanges
# these for an OAuth access token at runtime.
# dev.twitch.tv/console/apps → "Register Your Application".
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Steam — only used for the "Import Steam library" feature in the profile
# page. The recommendation pipeline doesn't use this. Optional; if unset,
# the Steam import button surfaces a "configure STEAM_API_KEY" error.
# Get a free key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Jikan (anime + manga via MyAnimeList): no key required, rate-limited to 3 req/s.
# Open Library (books): no key required, please rate-limit yourself.

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Client (Vite — VITE_ prefix is required to reach the browser) ────────
VITE_API_BASE_URL=/api
VITE_CLERK_PUBLISHABLE_KEY=
