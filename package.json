{
  "name": "resonance",
  "version": "0.0.1",
  "private": true,
  "description": "Cross-media AI recommendation engine",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm --filter @resonance/client dev",
    "dev:server": "pnpm --filter @resonance/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @resonance/server db:generate",
    "db:migrate": "pnpm --filter @resonance/server db:migrate",
    "db:studio": "pnpm --filter @resonance/server db:studio"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}