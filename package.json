{
  "name": "resonance",
  "version": "0.0.1",
  "private": true,
  "description": "Cross-media AI recommendation engine",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm --filter @resonance/client dev",
    "dev:server": "pnpm --filter @resonance/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @resonance/server db:generate",
    "db:migrate": "pnpm --filter @resonance/server db:migrate",
    "db:studio": "pnpm --filter @resonance/server db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
