{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @resonance/client build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "trailingSlash": false,
  "cleanUrls": false,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
